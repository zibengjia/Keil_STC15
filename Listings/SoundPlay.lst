  15          
  16          /*说明**************************************************************************
  17           曲谱存贮格式 unsigned char code MusicName{音高，音长，音高，音长...., 0,0};    末尾:0,0 表示结束(Important)
  18          
  19           音高由三位数字组成：
  20                   个位是表示 1~7 这七个音符 
  21                   十位是表示音符所在的音区:1-低音，2-中音，3-高音;
  22                   百位表示这个音符是否要升半音: 0-不升，1-升半音。
  23           
  24           音长最多由三位数字组成： 
  25                   个位表示音符的时值，其对应关系是： 
  26                       |数值(n):  |0 |1 |2 |3 | 4 | 5 | 6 
  27                       |几分音符: |1 |2 |4 |8 |16 |32 |64                 音符=2^n
  28                   十位表示音符的演奏效果(0-2):  0-普通，1-连音，2-顿音
  29                   百位是符点位: 0-无符点，1-有符点
  30          
  31           调用演奏子程序的格式
  32                   Play(乐曲名,调号,升降八度,演奏速度);
  33              |乐曲名           : 要播放的乐曲指针,结尾以(0,0)结束;
  34              |调号(0-11)       : 是指乐曲升多少个半音演奏;
  35              |升降八度(1-3)        : 1:降八度, 2:不升不降, 3:升八度;
  36              |演奏速度(1-12000): 值越大速度越快;
  37          
  38          ***************************************************************************/
  39          #ifndef __SOUNDPLAY_H_REVISION_FIRST__
  40          #define __SOUNDPLAY_H_REVISION_FIRST__
  41          
  42          #include <STC15F2K60S2.H>  // 引用STC15头文件，如果没有请换成 <reg52.h> 并手动定义 AUXR
  43          
  44          
  45          
  46          //**************************************************************************
  47          
  48          #define SYSTEM_OSC              11059200UL  // 定义晶振频率，使用UL确保为无符号长整型
  49          #define SOUND_SPACE     4/5         // 定义普通音符演奏的长度分率
  50          sbit    BeepIO    =     P1^6;           // 定义输出管脚
  51          
  52          unsigned int  code FreTab[12]  = { 262,277,294,311,330,349,369,392,415,440,466,494 }; //原始频率表
  53          unsigned char code SignTab[7]  = { 0,2,4,5,7,9,11 };                                                                //1~7在频率表中的位置
  54          unsigned char code LengthTab[7]= { 1,2,4,8,16,32,64 };                                          
C51 COMPILER V9.59.0.0   SOUNDPLAY                                                         03/25/2026 20:26:57 PAGE 2   

  55          unsigned char Sound_Temp_TH0,Sound_Temp_TL0;    //音符定时器初值暂存 
  56          unsigned char Sound_Temp_TH1,Sound_Temp_TL1;    //音长定时器初值暂存
  57          
  58          //**************************************************************************
  59          void InitialSound(void)
  60          {
  61   1          // --- C51标准：变量声明必须放在函数最前面 ---
  62   1          unsigned int T1_Reload; 
  63   1          // ----------------------------------------
  64   1      
  65   1          BeepIO = 1;
  66   1          
  67   1          //--- 定时器1配置 (节拍) ---
  68   1          // STC15 1T模式下，Timer1如果不分频，10ms计数会溢出(110592个计数 > 65535)
  69   1          // 因此 Timer1 必须设置为 12T 模式
  70   1          // 10ms = 11059200 / 12 / 100 = 9216 个计数
  71   1          // 重装载值 = 65536 - 9216 = 56320 (0xDC00)
  72   1          T1_Reload = 65536UL - (SYSTEM_OSC / 12 / 100); 
  73   1          
  74   1          Sound_Temp_TH1 = T1_Reload / 256;
  75   1          Sound_Temp_TL1 = T1_Reload % 256;
  76   1          
  77   1          //--- 定时器配置寄存器设置 ---
  78   1          TMOD  = 0x11;   // T0和T1都设置为模式1 (16位定时器)
  79   1          
  80   1          // STC15 AUXR寄存器设置:
  81   1          // Bit 7 (T0x12): 1=1T模式, 0=12T模式. 我们设为1，产生高频方波
  82   1          // Bit 6 (T1x12): 1=1T模式, 0=12T模式. 我们设为0，防止10ms溢出
  83   1          // Bit 4-5 等其他位保持默认
  84   1          AUXR |=  0x80;  // 1000 0000 -> T0设为1T
  85   1          AUXR &= ~0x40;  // 1011 1111 -> T1设为12T (清除bit6)
  86   1      
  87   1          TH1 = Sound_Temp_TH1;
  88   1          TL1 = Sound_Temp_TL1;
  89   1          
  90   1          ET0    = 1;     // 开启T0中断
  91   1          ET1    = 0;     // T1用于查询，不开启中断
  92   1          TR0    = 0;     // 初始不播放
  93   1          TR1    = 0;
  94   1          EA     = 1;
  95   1      }
  96          
  97          void BeepTimer0(void) interrupt 1       //音符发生中断 (T0)
  98          {
  99   1          BeepIO = !BeepIO;
 100   1          // 重新加载初值
 101   1          TH0    = Sound_Temp_TH0;
 102   1           TL0    = Sound_Temp_TL0;
 103   1      }
 104          //**************************************************************************
 105          void Play(unsigned char *Sound,unsigned char Signature,unsigned Octachord,unsigned int Speed)
 106          {
 107   1          unsigned int NewFreTab[12];         //新的频率表
 108   1          unsigned char i,j;
 109   1          unsigned int Point,LDiv,LDiv0,LDiv1,LDiv2,LDiv4,CurrentFre,Temp_T,SoundLength;
 110   1          unsigned char Tone,Length,SL,SH,SM,SLen,XG,FD;
 111   1          
 112   1          for(i=0;i<12;i++)                           // 根据调号及升降八度来生成新的频率表 
 113   1          {
 114   2              j = i + Signature;
 115   2              if(j > 11)
 116   2              {
C51 COMPILER V9.59.0.0   SOUNDPLAY                                                         03/25/2026 20:26:57 PAGE 3   

 117   3                  j = j-12;
 118   3                  NewFreTab[i] = FreTab[j]*2;
 119   3              }
 120   2              else
 121   2                  NewFreTab[i] = FreTab[j];
 122   2      
 123   2              if(Octachord == 1)
 124   2                  NewFreTab[i]>>=2;   // 降八度 (除以4)
 125   2              else if(Octachord == 3)
 126   2                  NewFreTab[i]<<=2;   // 升八度 (乘以4)
 127   2          }                                                                   
 128   1          
 129   1          SoundLength = 0;
 130   1          while(Sound[SoundLength] != 0x00)   //计算歌曲长度
 131   1          {
 132   2              SoundLength+=2;
 133   2          }
 134   1      
 135   1          Point = 0;
 136   1          Tone   = Sound[Point];      
 137   1          Length = Sound[Point+1];                    // 读出第一个音符和它时时值
 138   1          
 139   1          LDiv0 = 12000/Speed;                                // 算出1分音符的长度(单位:10ms)  <-- 这里假设基准是10ms
 140   1          LDiv4 = LDiv0/4;                                    // 算出4分音符的长度 
 141   1          // 注意: 4/5 在C语言整数运算中结果为0。
 142   1          // 如果原意是间隔为长度的 4/5，这里其实是减去了0。
 143   1          // 建议修改为: LDiv4 = LDiv4 - (LDiv4 * 4 / 5); 
 144   1          // 为了保持原库逻辑，这里保持原样，实际效果是间隔为最大长度。
 145   1          LDiv4 = LDiv4 - LDiv4*SOUND_SPACE;  
 146   1          
 147   1          TR0   = 0;
 148   1          TR1   = 1;
 149   1          
 150   1          while(Point < SoundLength)
 151   1          {
 152   2              SL=Tone%10;                                                             //计算出音符 
 153   2              SM=Tone/10%10;                                                          //计算出高低音 
 154   2              SH=Tone/100;                                                            //计算出是否升半 
 155   2              
 156   2              if(SL!=0)
 157   2              {
 158   3                  CurrentFre = NewFreTab[SignTab[SL-1]+SH]; //查出对应音符的频率      
 159   3                  
 160   3                  if (SM==1) CurrentFre >>= 2;                //低音 
 161   3                  if (SM==3) CurrentFre <<= 2;                //高音
 162   3                  
 163   3                  //--- STC15 1T 模式下 Timer0 计算公式 --- 
 164   3                  // 计数频率 = SYSTEM_OSC (1T)
 165   3                  // 周期 T = 1 / Freq
 166   3                  // 半周期 (翻转一次) = T / 2 = 1 / (2 * Freq)
 167   3                  // 计数个数 = 半周期 * 计数频率 = SYSTEM_OSC / (2 * CurrentFre)
 168   3                  Temp_T = 65536UL - (SYSTEM_OSC / CurrentFre / 2); 
 169   3                  
 170   3                  Sound_Temp_TH0 = Temp_T/256; 
 171   3                  Sound_Temp_TL0 = Temp_T%256; 
 172   3                  TH0 = Sound_Temp_TH0;  
 173   3                  TL0 = Sound_Temp_TL0; 
 174   3              }
 175   2              
 176   2              SLen=LengthTab[Length%10];      //算出是几分音符
 177   2              XG=Length/10%10;                        //算出音符类型(0普通1连音2顿音) 
 178   2              FD=Length/100;
C51 COMPILER V9.59.0.0   SOUNDPLAY                                                         03/25/2026 20:26:57 PAGE 4   

 179   2              LDiv=LDiv0/SLen;                        //算出连音音符演奏的长度(多少个10ms)
 180   2              if (FD==1) 
 181   2                  LDiv=LDiv+LDiv/2;
 182   2                  
 183   2              if(XG!=1)       
 184   2                  if(XG==0)                           //算出普通音符的演奏长度 
 185   2                      if (SLen<=4)    
 186   2                          LDiv1=LDiv-LDiv4;
 187   2                      else
 188   2                          LDiv1=LDiv*SOUND_SPACE; //整数运算结果为0，即LDiv1=0
 189   2                  else
 190   2                      LDiv1=LDiv/2;           //算出顿音的演奏长度 
 191   2              else
 192   2                  LDiv1=LDiv;
 193   2                  
 194   2              if(SL==0) LDiv1=0;
 195   2              LDiv2=LDiv-LDiv1;               //算出不发音的长度 
 196   2              
 197   2              if (SL!=0)
 198   2              {
 199   3                  TR0=1;
 200   3                  for(i=LDiv1;i>0;i--)        //发规定长度的音 
 201   3                  {
 202   4                      while(TF1==0);       // 等待10ms到 (T1为12T模式，初值已设为10ms)
 203   4                      TH1 = Sound_Temp_TH1;
 204   4                      TL1 = Sound_Temp_TL1;
 205   4                      TF1=0;
 206   4                  }
 207   3              }
 208   2              if(LDiv2!=0)
 209   2              {
 210   3                  TR0=0; BeepIO=1;
 211   3                  for(i=LDiv2;i>0;i--)        //音符间的间隔
 212   3                  {
 213   4                      while(TF1==0);
 214   4                      TH1 = Sound_Temp_TH1;
 215   4                      TL1 = Sound_Temp_TL1;
 216   4                      TF1=0;
 217   4                  }
 218   3              }
 219   2              Point+=2; 
 220   2              Tone=Sound[Point];
 221   2              Length=Sound[Point+1];
 222   2          }
 223   1          BeepIO = 1;
 224   1          TR0 = 0;
 225   1      }
 226          //**************************************************************************
 227          #endif



  48          /***********************************************
  49          函数名称：HC595_SendWord
  50          功    能：HC595发送两个字节数据。
  51          入口参数：dat:显示的字型码
  52                              dig:点亮的数码管位 dig中为0的位，则对应的数码管点亮
  53                    例如:dig=0x1111 1110,将dig送入U3芯片HC595后，最低位的0数据
  54                    将出现在原理图的Q0管脚，则该脚对应的数码管点亮，其他数码管熄灭。
C51 COMPILER V9.59.0.0   HC595                                                             04/18/2026 23:02:51 PAGE 2   

  55          返 回 值：无
  56          备    注：两片HC595，发送两个字节数据，高字节
  57                    为数码管段码，低字节为选择点亮哪个数码管。
  58                              该程序点亮数码管可以结合原理图来看，
  59                              否则不好理解，和电路原理关系密切。
  60          ************************************************/
  61          void HC595_SendWord(unsigned char dat, unsigned char dig)
  62          {
  63   1          unsigned char i;       // 定义计数器
  64   1          unsigned int temp = 0; // 定义数据变量
  65   1          // 将两个8位变量合并成一个16字节变量
  66   1          temp = dat;
  67   1          temp = temp << 8 | dig;
  68   1          // 送出数据
  69   1          for (i = 0; i < 16; i++) {
  70   2              HC595_SCK_Clr(); // 置低时钟线
  71   2      
  72   2              if ((temp & 0x8000) == 0x8000) // 先发送高字节
  73   2              {
  74   3                  HC595_DAT_Set(); // 置高信号线
  75   3              } else {
  76   3                  HC595_DAT_Clr(); // 置低信号线
  77   3              }
  78   2              HC595_SCK_Set(); // 置高时钟线
  79   2      
  80   2              temp <<= 1; // 数据左移
  81   2          }
  82   1          // 锁存信号上升沿锁存数据 数据输出到端口
  83   1          HC595_RCK_Clr();
  84   1          HC595_RCK_Set();
  85   1      }

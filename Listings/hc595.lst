 140          /***********************************************
 141          函数名称：HC595_Init
 142          功    能：显示初始化函数
 143          入口参数：无
 144          返 回 值：无
 145          备    注：无
 146          ************************************************/
 147          void HC595_Init(void)
 148          {
 149   1          // 等待HC595上电稳定
 150   1          HC595_Delayms(10);
 151   1      
 152   1          // 初始化P41,P42,P45口为准双向口
 153   1          P4M1 &= ~((1 << 1) | (1 << 2) | (1 << 5));
 154   1          P4M0 &= ~((1 << 1) | (1 << 2) | (1 << 5));
 155   1      
 156   1          // 初始化P37口为准双向口
 157   1          P3M1 &= ~(1 << 7);
 158   1          P3M0 &= ~(1 << 7);
 159   1      
 160   1          // 分析
 161   1          //   1<<0等价于0x01 即 0000 0001
 162   1          //   1<<1等价于0x02 即 0000 0010
 163   1          //   1<<2等价于0x04 即 0000 0100
 164   1          //   1<<3等价于0x08 即 0000 1000
 165   1          //   以此类推1<<n 即第n位为1，其余位是0
 166   1      
 167   1          //  x |=(1<<n)  即对x执行按位取或
 168   1          //  即x中的第n位置为1，不改变其他位状态
 169   1      
 170   1          //  y &=~(1<<n)  即将1<<n按位取反，然后对y按位取与
 171   1          //  即y中的第n位置为0，不改变其他位状态
 172   1      
 173   1          // 将端口置低，赋予端口固定电平
 174   1          HC595_DAT_Clr();
 175   1          HC595_SCK_Clr();
 176   1          HC595_RCK_Clr();
 177   1          // 关闭显示
 178   1          HC595_OE_Set();

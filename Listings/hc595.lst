 135          函数名称：HC595_Init
 136          功    能：显示初始化函数
 137          入口参数：无
 138          返 回 值：无
 139          备    注：无
 140          ************************************************/
 141          void HC595_Init(void)
 142          {
 143   1          // 等待HC595上电稳定
 144   1          HC595_Delayms(10);
 145   1      
 146   1          // 初始化P41,P42,P45口为准双向口
 147   1          P4M1 &= ~((1 << 1) | (1 << 2) | (1 << 5));
 148   1          P4M0 &= ~((1 << 1) | (1 << 2) | (1 << 5));
 149   1      
 150   1          // 初始化P37口为准双向口
 151   1          P3M1 &= ~(1 << 7);
 152   1          P3M0 &= ~(1 << 7);
 153   1      
 154   1          // 分析
 155   1          //   1<<0等价于0x01 即 0000 0001
 156   1          //   1<<1等价于0x02 即 0000 0010
 157   1          //   1<<2等价于0x04 即 0000 0100
 158   1          //   1<<3等价于0x08 即 0000 1000
 159   1          //   以此类推1<<n 即第n位为1，其余位是0
 160   1      
 161   1          //  x |=(1<<n)  即对x执行按位取或
 162   1          //  即x中的第n位置为1，不改变其他位状态
 163   1      
 164   1          //  y &=~(1<<n)  即将1<<n按位取反，然后对y按位取与
 165   1          //  即y中的第n位置为0，不改变其他位状态
 166   1      
 167   1          // 将端口置低，赋予端口固定电平
 168   1          HC595_DAT_Clr();
 169   1          HC595_SCK_Clr();
 170   1          HC595_RCK_Clr();
 171   1          // 关闭显示
 172   1          HC595_OE_Set();
 173   1          // 清除显示内容
 174   1          HC595_Clear();
 175   1          Timer2_Init();
 176   1      }

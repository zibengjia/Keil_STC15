  31          void Timer2_Init(void)
  32          {
  33   1          // 12T模式，定时器模式
  34   1          AUXR &= 0xFB; // 12T
  35   1          AUXR &= 0xF7; // 定时模式
  36   1      
  37   1          // 10ms初值计算：65536 - 11059200/12 * 0.01 = 65536 - 9216 = 56320
  38   1          T2H = 0xDC; // 高8位

  87          函数名称：LED_Display
  88          功    能：数码管显示函数
  89          入口参数：无
  90          返 回 值：无
  91          备    注：无
  92          ************************************************/
  93          void LED_Display(void)
  94          {
  95   1          // 使用静态变量，要不每次调用该函数的时候LED_Cnt都为0，无法累计计数。
  96   1          static unsigned char LED_Cnt = 0;
  97   1          // 将待显示的字型码和点亮的数码管位送至HC595。
  98   1          // 由于是共阴数码管，将八段数码管共阴极拉低，显示数据。
  99   1          // DispBuf[LED_Cnt]:为显示的内容
 100   1          // DispCode[DispBuf[LED_Cnt]:为将显示的内容转换成对应的字形码
 101   1          // 数码管按字形码显示出来就是我们看到的显示内容
 102   1      
 103   1          //~(0x01<<LED_Cnt),当LED_Cnt=0时等价于:0x1111 1110 当LED_Cnt=1时等价于：0x1111 1101
 104   1          // 以此类推，依次有一位为0，为0的位对应的数码管点亮
 105   1          HC595_OE_Set(); // 关闭显示
 106   1      
 107   1          // 将待显示的字型码和点亮的数码管号送到端口
 108   1          HC595_SendWord(DispCode[DispBuf[LED_Cnt]], (~(0x01 << LED_Cnt)));
 109   1      
 110   1          HC595_OE_Clr(); // 打开显示
 111   1      
 112   1          LED_Cnt++;        // 计数器加1
 113   1          if (LED_Cnt == 8) // 扫描八位数码管
 114   1          {
 115   2              LED_Cnt = 0;
 116   2          }

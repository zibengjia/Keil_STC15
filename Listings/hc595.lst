  26          void Timer2_Init(void)
  27          {
  28   1          // 12T模式，定时器模式
  29   1          AUXR &= 0xFB; // 12T
  30   1          AUXR &= 0xF7; // 定时模式
  31   1      
  32   1          // 10ms初值计算：65536 - 11059200/12 * 0.01 = 65536 - 9216 = 56320
  33   1          T2H = 0xDC; // 高8位
  34   1          T2L = 0x00; // 低8位
  35   1      
  36   1          IE2 |= 0x04;  // 使能T2中断

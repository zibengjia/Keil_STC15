 119          void HC595_Clear(void)
 120          {
 121   1          unsigned char i;
 122   1          // 清除显示缓冲区内容
 123   1          for (i = 0; i < 8; i++) {
 124   2              // 35为DispCode[35]中定义的数码管熄灭的字形码
 125   2              DispBuf[i] = 35;
 126   2          }
 127   1      
 128   1          // 数据0x00为字形码，0xff为数码管位码
 129   1          // 由原理图可知该开发板使用共阴极数码管
 130   1          // 共阴极数码管特点是字形码端高电平，位码端低电平，数码管才能点亮
 131   1          // 现在发送的字形码全为低电平，位码全为高电平，所以全部熄灭
 132   1          HC595_SendWord(0x00, 0xff);
 133   1      }

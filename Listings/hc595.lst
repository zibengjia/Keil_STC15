  42          /***********************************************
  43          函数名称：HC595_SendWord
  44          功    能：HC595发送两个字节数据。
  45          入口参数：dat:显示的字型码
  46                              dig:点亮的数码管位 dig中为0的位，则对应的数码管点亮
  47                    例如:dig=0x1111 1110,将dig送入U3芯片HC595后，最低位的0数据
  48                    将出现在原理图的Q0管脚，则该脚对应的数码管点亮，其他数码管熄灭。
  49          返 回 值：无
  50          备    注：两片HC595，发送两个字节数据，高字节
  51                    为数码管段码，低字节为选择点亮哪个数码管。
  52                              该程序点亮数码管可以结合原理图来看，
  53                              否则不好理解，和电路原理关系密切。
  54          ************************************************/
C51 COMPILER V9.59.0.0   HC595                                                             04/29/2026 18:27:09 PAGE 2   

  55          void HC595_SendWord(unsigned char dat, unsigned char dig)
  56          {
  57   1          unsigned char i;       // 定义计数器
  58   1          unsigned int temp = 0; // 定义数据变量
  59   1          // 将两个8位变量合并成一个16字节变量
  60   1          temp = dat;
  61   1          temp = temp << 8 | dig;
  62   1          // 送出数据
  63   1          for (i = 0; i < 16; i++) {
  64   2              HC595_SCK_Clr(); // 置低时钟线
  65   2      
  66   2              if ((temp & 0x8000) == 0x8000) // 先发送高字节
  67   2              {
  68   3                  HC595_DAT_Set(); // 置高信号线
  69   3              } else {
  70   3                  HC595_DAT_Clr(); // 置低信号线
  71   3              }
  72   2              HC595_SCK_Set(); // 置高时钟线
  73   2      
  74   2              temp <<= 1; // 数据左移
  75   2          }
  76   1          // 锁存信号上升沿锁存数据 数据输出到端口
  77   1          HC595_RCK_Clr();
  78   1          HC595_RCK_Set();
  79   1      }

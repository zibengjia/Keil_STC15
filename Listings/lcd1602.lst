 575   1          DateStr[4]  = (pClock->Month & 0x0F) + '0';        // дТИіЮЛ
 576   1          DateStr[5]  = '/';
 577   1          DateStr[6]  = ((pClock->Day >> 4) & 0 + 0x0F) + '0'; // ШеЪЎЮЛ

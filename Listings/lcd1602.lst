 153          ************************************************/
 154          void LCD1602_Init(void)  
 155          {       
 156   1              //初始化P0口为准双向口
 157   1              P0M1 =0x00;  
 158   1              P0M0 =0x00; 
 159   1              
 160   1              //初始化P41,P42口为准双向口
 161   1              P4M1 &=~( (1<<1) | (1<<2) );  
 162   1              P4M0 &=~( (1<<1) | (1<<2) ); 
 163   1              
 164   1              //初始化P37口为准双向口
 165   1              P3M1 &=~(1<<7);  
 166   1              P3M0 &=~(1<<7);   
 167   1                              
 168   1              //分析
 169   1              //  1<<0等价于0x01 即 0000 0001
 170   1              //  1<<1等价于0x02 即 0000 0010
 171   1              //  1<<2等价于0x04 即 0000 0100
 172   1              //  1<<3等价于0x08 即 0000 1000
 173   1              //  以此类推1<<n 即第n位为1，其余位是0
 174   1      
 175   1              //  x |=(1<<n)  即对x执行按位取或 
 176   1              //  即x中的第n位置为1，不改变其他位状态  
 177   1              
 178   1              //  y &=~(1<<n)  即将1<<n按位取反，然后对y按位取与 

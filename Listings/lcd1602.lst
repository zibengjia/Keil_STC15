 179   1              //  即y中的第n位置为0，不改变其他位状态     
 180   1      
 181   1        LCD1602_Delay1ms(15);   //上电延时15ms
 182   1        LCD1602_WriteCMD(0x38); //写显示指令(不检测忙信号)
 183   1        LCD1602_Delay1ms(5);
 184   1        LCD1602_WriteCMD(0x38); //写显示指令(不检测忙信号)

 202          /***********************************************
 203          函数名称：App_FormatDec
 204          功    能：整型数据转字符串函数
 205          入口参数：value:整型数据
 206          返 回 值：pstr：指向字符串的指针。      
 207          备    注：无
 208          ************************************************/
 209          void  App_FormatDec (unsigned char *pstr, unsigned char value)
 210          {
 211   1        unsigned char   i;
 212   1        unsigned int   mult; 
 213   1        unsigned int   nbr;
 214   1      
 215   1        mult  = 1;
 216   1              //因为这里要处理的value输入格式为三位数，例如123
 217   1              //故初始让mult=100
 218   1        for (i = 0; i < 2; i++) 
 219   1              {
 220   2          mult *= 10;
 221   2        }
 222   1      
 223   1              i=0;
 224   1        while (mult > 0) 
 225   1              {
 226   2                      i++;
 227   2                      //第一次整除，获取最高位数据，例如123/100=1
 228   2                      //其他位类推
 229   2          nbr = value / mult;
 230   2                      //如果得到的数据不是0
 231   2          if (nbr != 0) 
 232   2                {
 233   3                              //整型数据+'0'，将自动转换成字符数据，例如1+'0'将变成字符'1'
 234   3            *pstr = nbr + '0';
 235   3          } 
 236   2                else
 237   2                      {   
 238   3                              //如果数据是0，则直接转换成字符'0'          
 239   3            *pstr = '0';
 240   3          }
C51 COMPILER V9.59.0.0   LCD1602                                                           04/18/2026 23:02:51 PAGE 5   

 241   2                      //移动指针，进行其他位数据处理
 242   2          pstr++;
 243   2          value %= mult;
 244   2          mult  /= 10;
 245   2        }
 246   1      }
